# --- Required ---
# OpenAI API key (a frontier model is recommended for reliable tool use)
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API key for web search (https://tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# --- Optional ---
# Model to use. Defaults to gpt-4.1 (frontier, supports custom temperature).
# NOTE: gpt-5* models only accept the default temperature — see agent.py.
OPENAI_MODEL=gpt-4.1

# Where saved lesson plans are written (default: ./lesson_plans)
LESSON_PLANS_DIR=lesson_plans

# Master-teacher review loop (critique + auto-refine each plan). Default on.
# REVIEW_ENABLED=false

# --- Grafana AI Observability (OpenLIT / OpenTelemetry) ---
# Tracing turns on automatically when OTEL_EXPORTER_OTLP_ENDPOINT is set,
# or force it with TRACING_ENABLED=true. Set false to disable entirely.
# TRACING_ENABLED=true
OTEL_SERVICE_NAME=kinder-lesson-planner
OTEL_DEPLOYMENT_ENVIRONMENT=dev

# Local Docker stack (see observability/docker-compose.yaml): OTLP/HTTP collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Grafana Cloud instead? Use your stack's OTLP gateway + base64 creds:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceID:token)>

# LangSmith tracing (optional — for observability)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=kinder-lesson-planner
